# ===========================================
# Orphanage Information System — Environment
# Скопируй этот файл в .env и при необходимости замени значения
# ===========================================

# PostgreSQL
POSTGRES_DB=orphanage
POSTGRES_USER=orphanage_user
POSTGRES_PASSWORD=orphanage_secret
POSTGRES_PORT=5432

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180
KEYCLOAK_REALM=orphanage
KEYCLOAK_CLIENT_ID=orphanage-app

# RabbitMQ
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=rabbit_secret
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Services ports
EUREKA_PORT=8761
GATEWAY_PORT=8080
CHILDREN_SERVICE_PORT=8081
STAFF_SERVICE_PORT=8082
ADOPTION_SERVICE_PORT=8083
INVENTORY_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
